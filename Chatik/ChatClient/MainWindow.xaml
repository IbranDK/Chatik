<Window x:Class="ChatClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Чат Клиент" Height="400" Width="600">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <TextBox x:Name="NameInput" Width="100" Margin="0,0,5,0" Tag="Никнейм"/>
            <Button Content="Подключиться" Click="Connect_Click"/>
        </StackPanel>

        <ListBox x:Name="ChatBox" Grid.Row="1" />

        <DockPanel Grid.Row="2" Margin="0,10,0,0">
            <Button DockPanel.Dock="Right" Content="Отправить" Width="80" Click="Send_Click"/>
            <TextBox x:Name="MsgInput" KeyDown="MsgInput_KeyDown"/>
        </DockPanel>
    </Grid>
</Window>