<Window x:Class="ProjectServer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сервер чата" Height="400" Width="600">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="BtnStart" Content="Запустить" Width="100" Margin="0,0,10,0" Click="BtnStart_Click"/>
            <Button x:Name="BtnStop" Content="Остановить" Width="100" IsEnabled="False" Click="BtnStop_Click"/>
            <TextBlock x:Name="TxtStatus" Text="Статус: не запущен" VerticalAlignment="Center" Margin="20,0,0,0"/>
        </StackPanel>

        <ListBox x:Name="LogList" Grid.Row="1"/>

        <TextBlock Grid.Row="2" x:Name="TxtConnections" Text="Подключений: 0" Margin="0,10,0,0"/>
    </Grid>
</Window>